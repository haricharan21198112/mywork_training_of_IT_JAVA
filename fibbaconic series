import java.util.Scanner;
class fibbaconi
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        int n, a=1, b=0, i, c;
        System.out.println("enter the value of n:");
        n=sc.nextInt();
        for(i=1; i<=n; i++)
        {
            c=a+b;
            a=b;
            b=c;
            System.out.println("the result of series is:" + a);
        }
    }
}
