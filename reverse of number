import java.util.Scanner;
class reversenumber
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        int n, r, sum=0, i;
        System.out.println("enter the value of n:");
        n=sc.nextInt();
        for(i=1; i<=n; i++)
        {
            r=n%10;
            sum=(sum*10)+r;
            n=n/10;
        }
        System.out.println("the reverse number is:" + sum);
    }
}
