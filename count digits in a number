import java.util.Scanner;
class noofdigits
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        int n, temp, count=0;
        System.out.println("enter the value of number:");
        n=sc.nextInt();
        temp=Math.abs(n);
        if(temp==0)
        {
            count=1;
        }
        else
        {
            while(temp>0)
            {
                temp=temp/10;
                count++;
            }
        }
        System.out.println("the no of digits in number is:" + count);
    }
}
